DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=1
# Comma-separated hostnames, e.g. yourusername.pythonanywhere.com
DJANGO_ALLOWED_HOSTS=*
# Comma-separated full origins (scheme+host), e.g. https://yourusername.pythonanywhere.com
DJANGO_CSRF_TRUSTED_ORIGINS=

GEMINI_API_KEY=
GROK_API_KEY=
GROK_MODEL=llama-3.3-70b-versatile

# Unused in production (the dissertation chat flow is synchronous); only the legacy
# /generate-dissertation/ endpoint touches Celery, and nothing in the frontend calls it.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
